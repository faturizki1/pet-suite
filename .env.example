# ============================================
# Database
# ============================================
# PostgreSQL connection string
# Format: postgres://user:password@host:port/database
DATABASE_URL=postgres://user:password@localhost:5432/pet_suite

# ============================================
# Authentication
# ============================================
# Secret key for signing JWT tokens (min 32 characters, use a strong random value)
JWT_SECRET=your-random-jwt-secret-min-32-chars-long

# ============================================
# Storage (MinIO / S3-compatible)
# ============================================
# MinIO server endpoint URL (e.g., http://localhost:9000 or https://minio.domainanda.com)
MINIO_ENDPOINT=http://localhost:9000

# MinIO access key (username)
MINIO_ACCESS_KEY=your-minio-access-key

# MinIO secret key (password)
MINIO_SECRET_KEY=your-minio-secret-key

# Public base URL for accessing uploaded files
# Format: https://minio.domainanda.com or http://localhost:9000
MINIO_PUBLIC_URL=http://localhost:9000

# ============================================
# Environment
# ============================================
# Application environment: development | production | test
NODE_ENV=development